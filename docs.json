{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "NGS Docs",
  "colors": {
    "primary": "#a481f5",
    "light": "#4a3175",
    "dark": "#552d99"
  },
  "favicon": "/images/NGS-2-removebg-preview.png",
  "navigation": {
    "versions": [
      {
        "version": "v1",
        "tabs": [
          {
            "tab": "Product Installation",
            "icon": "brackets-curly",
            "pages": [
              "welcome",
              "terms-of-service",
              {
                "group": "CafePOS Lite",
                "icon": "coffee-pot",
                "pages": [
                  "installation",
                  "configuration",
                  "api",
                  "global-config"
                ]
              }
            ]
          },
          {
            "tab": "API reference",
            "icon": "server",
            "pages": [
              "api-reference/introduction",
              "api-reference/whitelist-add"
            ]
          }
        ]
      },
      {
        "version": "v2",
        "hidden": true
      }
    ]
  },
  "logo": "/images/NGS-2-removebg-preview.png",
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "discord": "https://discord.gg/s4k6VgNw"
    }
  },
  "api": {
    "playground": {
      "proxy": false
    }
  },
  "background": {
    "decoration": "grid",
    "color": {
      "light": "#ffffff",
      "dark": "#000000"
    }
  },
  "errors": {
    "404": {
      "redirect": true,
      "title": "Page Not Found",
      "description": "The page you are looking for does not exist."
    }
  }
}

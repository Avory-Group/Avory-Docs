{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Avory Docs",
  "colors": {
    "primary": "#a481f5",
    "light": "#4a3175",
    "dark": "#552d99"
  },
  "favicon": {
    "light": "/images/Avory-Logo.black.svg",
    "dark": "/images/Avory-Logo.white.svg"
  },
  "navigation": {
    "versions": [
      {
        "version": "v1",
        "tabs": [
          {
            "tab": "v1 Documentations",
            "icon": "airplay",
            "pages": [
              "welcome",
              "terms-of-service",
              {
                "group": "NGS CafePOS Lite",
                "icon": "coffee-pot",
                "pages": [
                  "ngs_cafepos_lite/installation",
                  "ngs_cafepos_lite/configuration",
                  "ngs_cafepos_lite/updating",
                  "ngs_cafepos_lite/api",
                  "ngs_cafepos_lite/gconfig"
                ],
                "expanded": true
              }
            ]
          },
          {
            "tab": "API reference",
            "icon": "server",
            "pages": [
              "api-reference/introduction",
              "api-reference/whitelist-add"
            ],
            "hidden": true
          }
        ]
      },
      {
        "version": "v2",
        "hidden": true
      }
    ]
  },
  "logo": {
    "light": "/images/Avory-Logo.black.svg",
    "dark": "/images/Avory-Logo.white.svg"
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "discord": "https://discord.gg/s4k6VgNw"
    }
  },
  "api": {
    "playground": {
      "proxy": false
    }
  },
  "background": {
    "decoration": "grid",
    "color": {
      "light": "#ffffff",
      "dark": "#000000"
    }
  },
  "errors": {
    "404": {
      "redirect": false,
      "title": "Page Not Found",
      "description": "The page you are looking for does not exist."
    }
  }
}  
